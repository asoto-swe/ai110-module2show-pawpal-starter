classDiagram
    class Owner {
        - name: str
        - preferences: dict
        + add_pet(pet)
        + remove_pet(pet)
    }

    class Pet {
        - name: str
        - species: str
        - age: int
        + add_task(task)
        + remove_task(task)
    }

    class Task {
        - title: str
        - duration_minutes: int
        - priority: str
        - due_time: datetime
        + is_high_priority()
    }

    class Scheduler {
        + build_daily_plan(owner)
        + sort_tasks(tasks)
        + explain_plan()
    }

    Owner "1" o-- "0..*" Pet
    Pet "1" o-- "0..*" Task
    Scheduler ..> Owner
    Scheduler ..> Task
